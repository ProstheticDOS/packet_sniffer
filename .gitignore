# =========================================================================
# 1. RUST / CARGO
# =========================================================================
# Block all build outputs and dependencies
target/

# Block backup files generated by rustfmt
**/*.rs.bk

# Block MSVC Windows debugging symbols
*.pdb

# Block rustc compiler panic traces
rustc-ice-*.txt

# =========================================================================
# 2. ANDROID / GRADLE
# =========================================================================
# Block built outputs
build/
app/build/

# CRITICAL: Block your local SDK path config (contains unique PC paths)
local.properties

*.jks
*.keystore
*.apk
*.aab

# Block Gradle internal cache and wrappers
.gradle/
/captures/
.cxx/

# =========================================================================
# 3. IDEs & SYSTEM (VS Code, Android Studio, macOS, Windows)
# =========================================================================
.idea/
*.iml
.DS_Store
Thumbs.db
